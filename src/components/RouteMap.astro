---
interface Segment {
  x1: number
  y1: number
  x2: number
  y2: number
  speed: number
  ele: number
  hr: number | null
}
interface Props {
  svgSegments: Segment[]
  viewBox: string
}
const { svgSegments, viewBox } = Astro.props

const hrs = svgSegments.map((s) => s.hr).filter((h): h is number => h !== null)
const minHr = Math.min(...hrs)
const maxHr = Math.max(...hrs)
const hrRange = maxHr - minHr || 1

const speeds = svgSegments.map((s) => s.speed)
const minSpeed = Math.min(...speeds)
const maxSpeed = Math.max(...speeds)
const speedRange = maxSpeed - minSpeed || 1

// red (hue 0) = fastest, blue (hue 240) = slowest
const hue = (speed: number) =>
  Math.round((1 - (speed - minSpeed) / speedRange) * 240)
const hasHr = hrs.length > 0

const OPACITY = 0.25
const OVERSHOOT = 1
const MIN_WIDTH = 1
const MAX_WIDTH = 4

// higher HR = thicker
const lineWidth = (hr: number | null) => {
  if (hr === null || !hasHr) return MIN_WIDTH
  return (
    (Math.round(
      (MIN_WIDTH + ((hr - minHr) / hrRange) * (MAX_WIDTH - MIN_WIDTH)) * 10
    ) /
      10) *
    Math.random() *
    2
  )
}

const extend = (s: Segment) => {
  const dx = s.x2 - s.x1
  const dy = s.y2 - s.y1
  const len = Math.sqrt(dx * dx + dy * dy) || 1
  const ux = (dx / len) * OVERSHOOT
  const uy = (dy / len) * OVERSHOOT
  return { x1: s.x1 - ux, y1: s.y1 - uy, x2: s.x2 + ux, y2: s.y2 + uy }
}
---

<div class="route-map">
  <svg viewBox={viewBox} xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    {
      svgSegments.map((s) => {
        const e = extend(s)
        return (
          <line
            x1={e.x1}
            y1={e.y1}
            x2={e.x2}
            y2={e.y2}
            stroke={`hsl(${hue(s.speed)},60%,52%)`}
            stroke-width={lineWidth(s.hr)}
            stroke-linecap="round"
            opacity={OPACITY}
          />
        )
      })
    }
  </svg>
</div>

<style>
  .route-map {
    background: var(--bg-color);
    overflow: hidden;
    margin: 0;
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }
  svg {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
